# Normalize line endings across platforms.
* text=auto eol=lf

# Explicitly declare text files.
*.md      text
*.markdown text
*.py      text
*.yml     text
*.yaml    text
*.json    text
*.toml    text
*.cfg     text
*.txt     text
*.html    text
*.css     text
*.js      text

# Windows-specific scripts keep CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Shell scripts keep LF.
*.sh      text eol=lf

# Binary assets — never diff or normalize.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.svg     text
*.ico     binary
*.pdf     binary
*.zip     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary

# Language statistics: treat docs as documentation, exclude vendored dirs.
docs/**   linguist-documentation
assets/** linguist-vendored
