# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: trailing whitespace can be meaningful (hard line break)
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Python
[*.py]
indent_size = 4
max_line_length = 100

# YAML
[*.{yml,yaml}]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
